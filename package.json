{
  "name": "fibiom-electron",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "main": ".vite/build/main.js",
  "author": "example.com",
  "license": "Apache-2.0",
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "yarn typecheck:node && yarn typecheck:web",
    "start": "electron-forge start -- --no-sandbox",
    "dev": "electron-forge start -- --no-sandbox",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "yarn typecheck",
    "artifacts": "bash scripts/collect-artifacts.sh",
    "artifacts:info": "bash scripts/collect-artifacts.sh --info",
    "seed": "bash scripts/seed.sh",
    "postinstall": "electron-rebuild -f -w better-sqlite3-multiple-ciphers,argon2"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@hookform/resolvers": "^5.4.0",
    "@hyperswarm/dht-relay": "^0.4",
    "@qvac/sdk": "^0.13.1",
    "@tailwindcss/vite": "^4.3.0",
    "argon2": "^0.44.0",
    "better-sqlite3-multiple-ciphers": "^12.10.0",
    "hyperdht": "^6",
    "lucide-react": "^1.17.0",
    "pdfjs-dist": "^6.0.227",
    "react-hook-form": "^7.78.0",
    "react-is": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "ws": "^8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^39.2.6",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "packageManager": "yarn@1.22.22"
}
